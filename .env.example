# ===== ブログ機能（microCMS）=====
# microCMS 管理画面 → サービス設定 で確認できます。
# サービスのURLが https://your-service.microcms.io の場合、SERVICE_DOMAIN は "your-service" の部分です。
MICROCMS_SERVICE_DOMAIN=your-service
# microCMS 管理画面 → サービス設定 → APIキー で取得（GET 権限があればOK）
MICROCMS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 公開サイトのURL（canonical / OGP 用。省略時は既定のNetlify URLを使用）
# SITE_URL=https://kaleidoscopic-wisp-45fdfc.netlify.app

# ===== Notion 取り込み用（旧: scripts/import-from-notion.js）=====
# https://www.notion.so/my-integrations でインテグレーションを作成し、シークレットをコピーして貼り付ける
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
